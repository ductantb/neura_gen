// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String   @id @default(uuid())
  email    String   @unique
  password String
  role     UserRole @default(FREE)

  //trỏ ngược lại
  credits   UserCredit?
  jobs      GenerateJob[]
  galleries GalleryItem[]
  posts     Post[]
  likes     PostLike[]
  comments  Comment[]
  followers Follow[]      @relation("followers")
  following Follow[]      @relation("following")

  createdAt          DateTime            @default(now())
  creditTransactions CreditTransaction[]
  canvasSessions     CanvasSession[]
}

model UserCredit {
  userId  String @id
  balance Int    @default(0)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt
}

model CreditTransaction {
  id     String @id @default(uuid())
  userId String
  amount Int
  reason String

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

enum UserRole {
  FREE
  PRO
  ADMIN
}

model GenerateJob {
  id             String  @id @default(uuid())
  userId         String
  type           JobType
  prompt         String
  negativePrompt String?
  modelName      String
  turboEnabled   Boolean @default(false)

  status   JobStatus @default(PENDING)
  progress Int       @default(0)

  extraConfig Json? // future-proof (style, lighting, camera...)

  assets Asset[]
  logs   JobLog[]

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

enum JobType {
  TEXT_TO_IMAGE
  IMAGE_TO_IMAGE
  IMAGE_TO_VIDEO
}

enum JobStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

model Asset {
  id    String    @id @default(uuid())
  jobId String
  type  AssetType

  versions AssetVersion[]

  job       GenerateJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
}

model AssetVersion {
  id      String @id @default(uuid())
  assetId String
  version Int

  fileUrl String
  seed    BigInt?
  width   Int?
  height  Int?
  quality String?

  metadata Json? // future AI params

  posts     Post[]
  asset     Asset         @relation(fields: [assetId], references: [id], onDelete: Cascade)
  galleries GalleryItem[]

  exploreItems ExploreItem[]
  createdAt    DateTime      @default(now())

  @@unique([assetId, version])
}

enum AssetType {
  IMAGE
  VIDEO
}

model ExploreItem {
  id             String @id @default(uuid())
  postId         String @unique
  assetVersionId String

  title      String
  topic      String
  isTrending Boolean @default(false)
  score      Float   @default(0)
  post       Post    @relation(fields: [postId], references: [id], onDelete: Cascade)

  assetVersion AssetVersion @relation(fields: [assetVersionId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  @@index([score])
  @@index([topic])
  @@index([isTrending])
}

model GalleryItem {
  id             String  @id @default(uuid())
  userId         String
  assetVersionId String
  isPublic       Boolean @default(false)

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetVersion AssetVersion @relation(fields: [assetVersionId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
}

model SmartIcon {
  id         String @id @default(uuid())
  name       String
  category   String
  attributes Json // default attributes (size, color, role...)
}

model CanvasSession {
  id     String @id @default(uuid())
  userId String
  layout Json // icon positions, sketch data

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model JobLog {
  id      String @id @default(uuid())
  jobId   String
  message String

  job       GenerateJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
}

model Post {
  id             String @id @default(uuid())
  userId         String
  assetVersionId String

  caption  String?
  isPublic Boolean @default(true)

  likeCount    Int @default(0)
  commentCount Int @default(0)
  viewCount    Int @default(0)

  user         User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  assetVersion AssetVersion @relation(fields: [assetVersionId], references: [id], onDelete: Restrict)

  likes    PostLike[]
  comments Comment[]
  views    PostView[]
  explore  ExploreItem?

  createdAt DateTime @default(now())
}

model PostLike {
  userId String
  postId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([userId, postId])
}

model Comment {
  id      String @id @default(uuid())
  userId  String
  postId  String
  content String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model PostView {
  id     String  @id @default(uuid())
  userId String?
  postId String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Follow {
  followerId  String
  followingId String

  follower  User @relation("following", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("followers", fields: [followingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([followerId, followingId])
}
