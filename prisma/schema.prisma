generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(uuid())
  email              String              @unique
  password           String
  username           String              
  bio                String?
  avatarUrl          String?
  role               UserRole            @default(FREE)
  createdAt          DateTime            @default(now())
  canvasSessions     CanvasSession[]
  comments           Comment[]
  creditTransactions CreditTransaction[]
  following          Follow[]            @relation("following")
  followers          Follow[]            @relation("followers")
  galleries          GalleryItem[]
  jobs               GenerateJob[]
  posts              Post[]
  likes              PostLike[]
  credits            UserCredit?
}

model UserCredit {
  userId    String   @id
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CreditTransaction {
  id        String   @id @default(uuid())
  userId    String
  amount    Int
  reason    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GenerateJob {
  id             String    @id @default(uuid())
  userId         String
  type           JobType
  prompt         String
  negativePrompt String?
  modelName      String
  turboEnabled   Boolean   @default(false)
  status         JobStatus @default(PENDING)
  progress       Int       @default(0)
  extraConfig    Json?
  createdAt      DateTime  @default(now())
  assets         Asset[]
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs           JobLog[]
}

model Asset {
  id        String         @id @default(uuid())
  jobId     String?
  type      AssetType
  createdAt DateTime       @default(now())
  job       GenerateJob?    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  versions  AssetVersion[]
}

model AssetVersion {
  id           String        @id @default(uuid())
  assetId      String
  version      Int
  fileUrl      String
  seed         BigInt?
  width        Int?
  height       Int?
  quality      String?
  metadata     Json?
  createdAt    DateTime      @default(now())
  asset        Asset         @relation(fields: [assetId], references: [id], onDelete: Cascade)
  exploreItems ExploreItem[]
  galleries    GalleryItem[]
  posts        Post[]

  @@unique([assetId, version])
}

model ExploreItem {
  id             String       @id @default(uuid())
  assetVersionId String
  title          String
  topic          String
  isTrending     Boolean      @default(false)
  score          Float        @default(0)
  createdAt      DateTime     @default(now())
  postId         String       @unique
  assetVersion   AssetVersion @relation(fields: [assetVersionId], references: [id])
  post           Post         @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([score])
  @@index([topic])
  @@index([isTrending])
}

model GalleryItem {
  id             String       @id @default(uuid())
  userId         String
  assetVersionId String
  isPublic       Boolean      @default(false)
  createdAt      DateTime     @default(now())
  assetVersion   AssetVersion @relation(fields: [assetVersionId], references: [id])
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SmartIcon {
  id         String @id @default(uuid())
  name       String
  category   String
  attributes Json
}

model CanvasSession {
  id        String   @id @default(uuid())
  userId    String
  layout    Json
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model JobLog {
  id        String      @id @default(uuid())
  jobId     String
  message   String
  createdAt DateTime    @default(now())
  job       GenerateJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model Post {
  id             String       @id @default(uuid())
  userId         String
  assetVersionId String
  caption        String?
  isPublic       Boolean      @default(true)
  likeCount      Int          @default(0)
  commentCount   Int          @default(0)
  viewCount      Int          @default(0)
  createdAt      DateTime     @default(now())
  comments       Comment[]
  explore        ExploreItem?
  assetVersion   AssetVersion @relation(fields: [assetVersionId], references: [id])
  user           User         @relation(fields: [userId], references: [id])
  likes          PostLike[]
}

model PostLike {
  id        String   @id @default(uuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model Comment {
  id        String   @id @default(uuid())
  userId    String
  postId    String
  content   String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("following", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

enum UserRole {
  FREE
  PRO
  ADMIN
}

enum JobType {
  TEXT_TO_IMAGE
  IMAGE_TO_IMAGE
  IMAGE_TO_VIDEO
}

enum JobStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

enum AssetType {
  IMAGE
  VIDEO
}
